{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!**/node_modules", "!!**/dist"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "suspicious": {
        "noConsole": {
          "level": "error",
          "options": {
            "allow": ["error", "info", "log", "warn"]
          }
        }
      },
      "nursery": {
        "noFloatingPromises": "error",
        "noShadow": "error"
      },
      "complexity": {
        "useNumericLiterals": "error",
        "noCommaOperator": "error",
        "noArguments": "error"
      }
    }
  },
  "javascript": {
    "globals": ["Bun", "CalendarApp", "PropertiesService", "ScriptApp"],
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
